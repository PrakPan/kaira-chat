 top: 15vh;
 box-shadow:yellow;
`
const Cardstyle=styled.div`


font-size:2rem;
padding:1rem;
`







 const Terms = () => { 
    let cards=[];
    let linkcards=[];
    const [CardText , setCardText]=useState(false);
    const [LinkCards,setLinkCards]=useState(false);
    useEffect(()=>{

        for(var i =0;i<content.length;i++){
    
            {
                cards.push(
                <SubHeading >
                    {content[i].subheading}
                </SubHeading>),
                linkcards.push(
                  <SubHeading >
                      
                     {content[i].subheading } 
                     
                </SubHeading>
                )
                
                
                
            }
            //ab text ko dhundo
            for(var j=0;j<content[i].content.length;j++){
                
               
                if(content[i].content[j].array){
                    //loop through it
                    for(var k =0;k<content[i].content[j].array.length;k++){
                        cards.push(
                            <StyleListItem>
                                {content[i].content[j].array[k]}
                             </StyleListItem>
                        )
                    }
        
                }else{
                  cards.push(
                      <TextContainer>
                          {content[i].content[j].text}
                      </TextContainer>
                  )
                }
            }
        } 

    setCardText(cards);
    setLinkCards(linkcards);
    },[])

     
    return(
      <>
      <Heading className='font-opensans' >
          Terms And Conditions
      </Heading>
     
        
        <Container>
            
            <Linkcardstyle className='border-thin'   >{LinkCards} </Linkcardstyle>
            
              
            <Cardstyle className='border-thin'  >   <div> {CardText} </div> </Cardstyle>
             
        </Container>
        
        <Navbar />
        <Section
          title="Section 1"
          subtitle={dummyText}
          dark={true}
          id="section1"
        />
        <Section
          title="Section 2"
          subtitle={dummyText}
          dark={false}
          id="section2"
        />
        <Section
          title="Section 3"
          subtitle={dummyText}
          dark={true}
          id="section3"
        />
        <Section
          title="Section 4"
          subtitle={dummyText}
          dark={false}
          id="section4"
        />
        <Section
          title="Section 5"
          subtitle={dummyText}
          dark={true}
          id="section5"
        />

        </>
    )
  
 }

export default Terms;